# ── Neuron Clinical Workstation Environment Configuration ──────────────────────

# JWT Cryptographic Secret Key
# Generate a secure one using: openssl rand -hex 32
# If left empty, the application will dynamically generate one on startup (invalidating sessions on restart).
JWT_SECRET=

# Anonymization Salt (Required for DPDP Compliance)
# Salt used for hashing patient identifiers (e.g. Patient ID, Name).
# MUST be kept secret and consistent across restarts to successfully retrieve past scan history.
NEURON_CLINIC_SALT=

# Default Admin Account
# Seeded only on first startup when the database is empty.
NEURON_ADMIN_USERNAME=admin
NEURON_ADMIN_PASSWORD=neuron2026

# Database & Cache URLs
# Production database should use PostgreSQL (e.g. postgresql://user:password@host:port/dbname)
DATABASE_URL=sqlite:///neuron_clinic.db
REDIS_URL=redis://localhost:6379/0

# Cloud Storage Configuration (AWS S3 or Cloudflare R2)
# Set to 'true' to use local mock storage under the mock_s3_bucket/ directory
MOCK_S3=true
S3_BUCKET_NAME=neuron-clinical-scans
S3_REGION=ap-south-1

# AWS Credentials (only used if MOCK_S3 is 'false')
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
